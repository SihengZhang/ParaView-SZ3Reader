// Auto-generated dispatcher implementation
// Supports SZ3 versions: @SZ3_SUPPORTED_VERSIONS_STRING@

#include "SZ3VersionDispatcher.h"
#include <cstring>
#include <sstream>
#include <map>

// Include version-specific wrappers
@SZ3_WRAPPER_INCLUDES@

// Thread-local error message storage
static thread_local std::string g_lastError;

uint32_t SZ3_ReadVersion(const char* cmpData, size_t cmpSize) {
    if (cmpSize < 8) {
        g_lastError = "Compressed data too small to contain header";
        return 0;
    }

    // Read magic number (bytes 0-3, little-endian)
    uint32_t magic = 0;
    std::memcpy(&magic, cmpData, 4);

    if (magic != SZ3_MAGIC_NUMBER) {
        g_lastError = "Invalid magic number - not an SZ3 compressed file";
        return 0;
    }

    // Read version (bytes 4-7, little-endian)
    uint32_t version = 0;
    std::memcpy(&version, cmpData + 4, 4);

    return version;
}

std::string SZ3_VersionToString(uint32_t version) {
    uint32_t major = (version >> 24) & 0xFF;
    uint32_t minor = (version >> 16) & 0xFF;
    uint32_t patch = (version >> 8) & 0xFF;

    std::ostringstream ss;
    ss << major << "." << minor << "." << patch;
    return ss.str();
}

uint32_t SZ3_VersionFromString(const std::string& version) {
    uint32_t major = 0, minor = 0, patch = 0;
    char dot;
    std::istringstream ss(version);
    ss >> major >> dot >> minor >> dot >> patch;
    return (major << 24) | (minor << 16) | (patch << 8);
}

// List of supported versions
static const std::vector<std::string> g_supportedVersions = {
@SZ3_SUPPORTED_VERSIONS_LIST@
};

bool SZ3_IsVersionSupported(uint32_t version) {
    std::string versionStr = SZ3_VersionToString(version);
    for (const auto& v : g_supportedVersions) {
        if (v == versionStr) return true;
    }
    return false;
}

std::vector<std::string> SZ3_GetSupportedVersions() {
    return g_supportedVersions;
}

const char* SZ3_GetLastError() {
    return g_lastError.c_str();
}

// Function pointer types for decompression
using DecompressFloatFunc = void(*)(const char*, size_t, float*, size_t);
using DecompressDoubleFunc = void(*)(const char*, size_t, double*, size_t);

// Dispatcher maps
static const std::map<std::string, DecompressFloatFunc> g_floatDispatchers = {
@SZ3_FLOAT_DISPATCHER_ENTRIES@
};

static const std::map<std::string, DecompressDoubleFunc> g_doubleDispatchers = {
@SZ3_DOUBLE_DISPATCHER_ENTRIES@
};

int SZ3_DecompressFloat(const char* cmpData, size_t cmpSize,
                        float* decData, size_t num, int dims[3]) {
    uint32_t version = SZ3_ReadVersion(cmpData, cmpSize);
    if (version == 0) {
        return -1; // Error already set
    }

    std::string versionStr = SZ3_VersionToString(version);

    auto it = g_floatDispatchers.find(versionStr);
    if (it == g_floatDispatchers.end()) {
        std::ostringstream ss;
        ss << "Unsupported SZ3 version: " << versionStr << ". Supported versions: ";
        for (size_t i = 0; i < g_supportedVersions.size(); ++i) {
            if (i > 0) ss << ", ";
            ss << g_supportedVersions[i];
        }
        g_lastError = ss.str();
        return -2;
    }

    try {
        it->second(cmpData, cmpSize, decData, num);
        return 0;
    } catch (const std::exception& e) {
        g_lastError = std::string("Decompression failed: ") + e.what();
        return -3;
    }
}

int SZ3_DecompressDouble(const char* cmpData, size_t cmpSize,
                         double* decData, size_t num, int dims[3]) {
    uint32_t version = SZ3_ReadVersion(cmpData, cmpSize);
    if (version == 0) {
        return -1; // Error already set
    }

    std::string versionStr = SZ3_VersionToString(version);

    auto it = g_doubleDispatchers.find(versionStr);
    if (it == g_doubleDispatchers.end()) {
        std::ostringstream ss;
        ss << "Unsupported SZ3 version: " << versionStr << ". Supported versions: ";
        for (size_t i = 0; i < g_supportedVersions.size(); ++i) {
            if (i > 0) ss << ", ";
            ss << g_supportedVersions[i];
        }
        g_lastError = ss.str();
        return -2;
    }

    try {
        it->second(cmpData, cmpSize, decData, num);
        return 0;
    } catch (const std::exception& e) {
        g_lastError = std::string("Decompression failed: ") + e.what();
        return -3;
    }
}
